st_drop_geometry() %>%
filter(LISA_cluster %in% c("Low-Low", "Low-High")) %>%
select(County_ID, NAME.x, Mortality_Rate_100000, LISA_cluster) %>%
arrange(County_ID)
global_moran
cor.test(data_sf$Mortality_Rate_100000, data_sf$Percent_in_Poverty)
lm_model <- lm(Mortality_Rate_100000 ~ Percent_in_Poverty, data = data_sf)
summary(lm_model)
tmap_mode("plot")
poverty_map <- tm_shape(data_sf) +
tm_polygons(
"Percent_in_Poverty",
style = "jenks",
n = 5,
palette = "Blues",
title = "Percent in Poverty (%)"
) +
tm_layout(
