data_sf$LISA_cat,
levels = c("High-High", "Low-Low", "Low-High", "High-Low", "Not Significant")
)
# 2. Labels ONLY for significant clusters
data_sf$label_num <- ifelse(
data_sf$LISA_cat %in% c("High-High", "Low-Low", "Low-High", "High-Low"),
data_sf$County_ID,
NA
)
# 3. Build map with perfect legend layout
lisa_map <- ggplot() +
geom_sf(data = data_sf, aes(fill = LISA_cat), color = "white", size = 0.2) +
geom_sf_text(
data = subset(data_sf, !is.na(label_num)),
aes(label = label_num),
size = 3,
color = "black"
) +
scale_fill_manual(
values = c(
"High-High" = "red",
"Low-Low" = "blue",
"Low-High" = "lightblue",
"High-Low" = "orange",
"Not Significant" = "grey80"
),
name = "LISA Clusters\n(Cancer Mortality)"
) +
theme_void() +
theme(
legend.position = c(0.15, 0.18),      # bottom left INSIDE the plot
legend.title = element_text(size = 12, face = "bold"),
legend.text = element_text(size = 10),
legend.background = element_rect(fill = "white", color = "black"),
legend.key.size = unit(0.5, "cm"),    # smaller keys like your sample
legend.margin = margin(5, 5, 5, 5),
plot.margin = margin(10, 10, 10, 10)
) +
guides(
fill = guide_legend(
title.position = "top",
title.hjust = 0.5,        # center title
label.hjust = 0,          # left-aligned text
ncol = 1,                 # vertical list EXACTLY like your sample
override.aes = list(size = 4)
)
)
lisa_map
