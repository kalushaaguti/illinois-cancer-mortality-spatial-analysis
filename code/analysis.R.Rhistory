data = subset(data_sf, !is.na(label_num)),
aes(label = label_num),
size = 3,
color = "black"
) +
scale_fill_manual(
values = c(
"High-High" = "red",
"Low-Low" = "blue",
"Low-High" = "lightblue",
"High-Low" = "orange",
"Not Significant" = "grey80"
),
drop = FALSE,
name = "LISA Clusters\n(Cancer Mortality)"
) +
theme_void() +
theme(
legend.position = "bottom",
legend.title = element_text(size = 12),
legend.text = element_text(size = 10)
)
lisa_map
