# 2. Global Moran’s I (you’ll use the output in the report)
global_moran <- moran.test(data_sf$Mortality_Rate_100000, lw)
global_moran
local_moran <- localmoran(data_sf$Mortality_Rate_100000, lw)
data_sf$LISA_cluster <- dplyr::case_when(
local_moran[,1] > 0 &
data_sf$Mortality_Rate_100000 > mean(data_sf$Mortality_Rate_100000) &
local_moran[,5] <= 0.05 ~ "High-High",
local_moran[,1] > 0 &
data_sf$Mortality_Rate_100000 < mean(data_sf$Mortality_Rate_100000) &
local_moran[,5] <= 0.05 ~ "Low-Low",
local_moran[,1] < 0 &
data_sf$Mortality_Rate_100000 > mean(data_sf$Mortality_Rate_100000) &
local_moran[,5] <= 0.05 ~ "High-Low",
local_moran[,1] < 0 &
data_sf$Mortality_Rate_100000 < mean(data_sf$Mortality_Rate_100000) &
local_moran[,5] <= 0.05 ~ "Low-High",
TRUE ~ "Not Significant"
)
table(data_sf$LISA_cluster)
data_sf$LISA_cluster <- factor(
data_sf$LISA_cluster,
levels = c("High-High", "Low-Low", "High-Low", "Low-High", "Not Significant")
)
lisa_map <- tm_shape(data_sf) +
tm_polygons(
"LISA_cluster",
palette = c("red", "blue", "orange", "lightblue", "grey85"),
title = "LISA Cluster Type",
textNA = "No Data"
) +
tm_layout(
frame = FALSE,
legend.outside = TRUE,
main.title = "Local Moran's I Clusters of Cancer Mortality\nIllinois, 2020",
main.title.size = 1
)
lisa_map
tmap_save(
lisa_map,
filename = "Cancer_LISA_Map_2020.png",
dpi = 300,
width = 8,
height = 6,
units = "in"
)
