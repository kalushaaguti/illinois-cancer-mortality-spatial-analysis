scatter_plot <- ggplot(data_sf, aes(x = Percent_in_Poverty, y = Mortality_Rate_100000)) +
geom_point(alpha = 0.7) +
geom_smooth(method = "lm", se = TRUE, color = "red") +
labs(
x = "Percent in Poverty (%)",
y = "Cancer Mortality Rate (per 100,000)",
title = "Relationship Between Poverty and Cancer Mortality in Illinois Counties (2020)"
) +
theme_minimal()
